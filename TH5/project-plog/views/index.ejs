<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Trang chủ</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container">

  <h1>📚 Danh sách bài viết</h1>

  <br>
  <!-- tạo bài -->
  <a href="/post/new" class="btn-create">+ Tạo bài viết</a>
  <br><br>
  <% if(posts.length === 0) { %>
    <p>Không có bài viết nào.</p>
  <% } %>
  <% posts.forEach(post => { %>
    <div class="post">
      <!-- ngày tạo -->
      <p class="date">
        📅 
        <%= post.createdAt 
            ? new Date(post.createdAt).toLocaleString("vi-VN") 
            : "Không có ngày" 
        %>
      </p>
      <!-- tiêu đề -->
      <h2><%= post.title %></h2>
      <!-- tóm tắt nội dung -->
      <p>
        <%= post.body.length > 120 
            ? post.body.substring(0,120) + "..." 
            : post.body 
        %>
      </p>
      <!-- nút chức năng -->
      <div class="actions">
        <a href="/post/<%= post._id %>" class="btn-view">Xem
        </a>
        <a href="/post/edit/<%= post._id %>" class="btn-edit">Sửa
        </a>
        <a 
          href="/post/delete/<%= post._id %>" 
          class="btn-delete"
          onclick="return confirm('Xóa bài viết này?')">Xóa
        </a>
      </div>
    </div>
    <hr>
  <% }) %>
</div>
</body>
</html>