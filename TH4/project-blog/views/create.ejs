<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Tạo bài viết</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="container">
      <h1>📝 Tạo bài viết mới</h1>

      <form action="/blogposts/store" method="POST">
        <input type="text" name="title" placeholder="Nhập tiêu đề..." />

        <textarea name="body" placeholder="Nhập nội dung..."> </textarea>

        <button type="submit">Lưu bài viết</button>
      </form>

      <a href="/" class="back">← Về trang chủ</a>
    </div>
  </body>
</html>
